PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_manager?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
# Опционально, если у Redis есть пароль
# REDIS_PASSWORD=

# Входящие сообщения: постановка в BullMQ и обработка воркером (снимает нагрузку LLM с HTTP вебхука). false — синхронно в вебхуке (без Redis).
DIALOG_QUEUE_ENABLED=true
# В этом процессе поднимать воркер очереди. false — только API/постановка (воркер на другом инстансе).
DIALOG_QUEUE_WORKER_ENABLED=true
# Параллельных задач диалога на один воркер-процесс (LLM тяжёлый — держите низким).
DIALOG_QUEUE_CONCURRENCY=2
# DIALOG_QUEUE_ATTEMPTS=5
# DIALOG_QUEUE_BACKOFF_MS=3000

WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_APP_SECRET=change-me

# ===== Multi-bot Telegram (Phase 7) =====
# Базовый URL для регистрации вебхуков всех ботов через scripts/telegram-webhook.mjs.
# Каждая сборка config/configurations/<id>.json с channel.telegram.{tokenEnv,webhookSecret}
# регистрируется как POST {BASE_URL}/webhooks/telegram/<webhookSecret>.
TELEGRAM_WEBHOOK_BASE_URL=https://yourdomain.com

# Токены ботов: одна env-переменная на каждый бот, имя задаётся в channel.telegram.tokenEnv
# Примеры (под salon-admin.json и pipe-sales.json — замените на реальные):
SALON_ADMIN_TG_TOKEN=токен_от_BotFather
PIPE_SALES_TG_TOKEN=токен_от_BotFather

# ===== Legacy single-bot (опционально, для одной сборки без channel.telegram) =====
# TELEGRAM_BOT_TOKEN=токен_от_BotFather
# TELEGRAM_WEBHOOK_URL=https://yourdomain.com/webhooks/telegram
# Сборка по умолчанию для legacy маршрута /webhooks/telegram (без secret).
BOT_CONFIGURATION=salon-admin

# ===== LLM =====
LLM_ENABLED=true
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3:latest
LLM_API_KEY=ollama
# Per-bot override доступен через config/configurations/<id>.json → llm.{temperature,maxTokens,contextMessages}.
# env LLM_TEMPERATURE / LLM_MAX_TOKENS / LLM_CONTEXT_MESSAGES используются только если в JSON не задано.
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=600
LLM_CONTEXT_MESSAGES=16
# Опционально: лимит ожидания LLM в мс. 0/пусто — без лимита.
# LLM_TIMEOUT_MS=30000

# В dev (NODE_ENV !== production) в лог пишется тело chat-запроса и превью ответа.
# Макс. длина content на сообщение в логе; 0 = без усечения.
LLM_DEV_LOG_TRUNCATE=4000
