PORT=3000
NODE_ENV=development

# Admin API (JWT). В production задайте сильные секреты; в development допустимы дефолты из кода (см. jwt.strategy / auth.service).
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_manager?schema=public
REDIS_HOST=localhost
REDIS_PORT=6379
# Опционально, если у Redis есть пароль
# REDIS_PASSWORD=

# Входящие сообщения: постановка в BullMQ и обработка воркером (снимает нагрузку LLM с HTTP вебхука). false — синхронно в вебхуке (без Redis).
DIALOG_QUEUE_ENABLED=true
# В этом процессе поднимать воркер очереди. false — только API/постановка (воркер на другом инстансе).
DIALOG_QUEUE_WORKER_ENABLED=true
# Параллельных задач диалога на один воркер-процесс (LLM тяжёлый — держите низким).
DIALOG_QUEUE_CONCURRENCY=2
# DIALOG_QUEUE_ATTEMPTS=5
# DIALOG_QUEUE_BACKOFF_MS=3000

WHATSAPP_VERIFY_TOKEN=change-me
WHATSAPP_ACCESS_TOKEN=change-me
WHATSAPP_PHONE_NUMBER_ID=change-me
WHATSAPP_APP_SECRET=change-me

TELEGRAM_BOT_TOKEN=твой_токен_от_BotFather
TELEGRAM_WEBHOOK_URL=https://твой-ngrok.ngrok-free.app/webhooks/telegram
# Максимальный размер файла (байты) при загрузке PDF/DOCX/TXT в онбординге базы знаний; по умолчанию 20971520 (20 MiB).
# TELEGRAM_DOCUMENT_MAX_BYTES=20971520

# Сборка: config/configurations/<имя>.json — open-topics (любые темы) | daria-mokko | test-saas | test-fitness | default
BOT_CONFIGURATION=daria-mokko

LLM_ENABLED=true
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=llama3:latest
LLM_API_KEY=ollama
# Ниже 0.5 — меньше «фантазий» и уходов в сторону (для строгой темы попробуй 0.25–0.4)
# Опционально: лимит ожидания Ollama в мс (например LLM_TIMEOUT_MS=30000). Не задавать или 0 — без лимита; при таймауте — встроенный текстовый шаблон из DialogService.
# Сколько последних сообщений диалога в запрос к LLM (меньше — обычно быстрее; по умолчанию в коде 16, если не задано)
LLM_CONTEXT_MESSAGES=6
LLM_TEMPERATURE=0.35
# Ограничение длины ответа (токены). Пусто = по умолчанию провайдера
LLM_MAX_TOKENS=400
# Профиль системного промпта (fallback, если не задан в config/configurations/<BOT_CONFIGURATION>.json)
# Скопируй default.json → свой_кейс.json в prompt-profiles и укажи llmPromptProfile в конфигурации бота
LLM_PROMPT_PROFILE=default
# В dev (NODE_ENV !== production) в лог пишется тело chat-запроса и превью ответа.
# Макс. длина content на сообщение в логе; 0 = без усечения (может быть очень длинно).
LLM_DEV_LOG_TRUNCATE=4000