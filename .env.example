# ── Required ───────────────────────────────────────────────
# Postgres (Prisma).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nanokernel?schema=public
# Redis — dialog queue + rate limiting.
REDIS_HOST=localhost
REDIS_PORT=6379
# Which bot to load: a folder under config/<id>/configuration.json.
BOT_CONFIGURATION=ai-programmer

# LLM
LLM_ENABLED=true
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=qwen/qwen3.5-9b
LLM_API_KEY=key

# ── Channel — only what your bot uses ──────────────────────
# The HTTP channel (POST /channels/http/message) needs nothing here.
# Telegram: var NAME is referenced by config → channel.telegram.tokenEnv.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_BASE_URL =
# WhatsApp (Meta Cloud API):
# WHATSAPP_VERIFY_TOKEN=        WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=     WHATSAPP_APP_SECRET=

# ── AI-programmer pack (packs/dev) ─────────────────────────
# Workspace the sandboxed dev MCP server may read/write/run in. Bind-mounted
# into the Docker sandbox as /workspace and referenced by config/mcp.json as
# ${DEV_WORKSPACE_ROOT}. Point it at a throwaway folder, NOT the repo.
# Build the sandbox image once: npm run dev:sandbox:build
DEV_WORKSPACE_ROOT=/path/to/agent-workspace

# ── Optional — sane defaults, override only if needed ──────
# PORT=3000   REDIS_PASSWORD=   CONFIG_ROOT=   MCP_CONFIG=
# DIALOG_QUEUE_ENABLED=true  DIALOG_QUEUE_WORKER_ENABLED=true  DIALOG_QUEUE_CONCURRENCY=2
# LLM_TEMPERATURE=0.5  LLM_MAX_TOKENS=600  LLM_CONTEXT_MESSAGES=16  LLM_TIMEOUT_MS=30000
# Salon vertical only: DARIA_MOKKO_MESTO_KEY=mst_live_...  (config → crm.apiKeyEnv)
