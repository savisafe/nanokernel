generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  ACTIVE
  CLOSED
  HANDED_OFF
}

model User {
  id            String         @id @default(cuid())
  externalId    String
  channel       String
  displayName   String?
  language      String         @default("ru")
  knowledgeScopeText String?
  /// Накопление черновика базы до команды /done
  knowledgeDraft     String?
  telegramKnowledgeAwaiting Boolean @default(false)
  /// Выбор сборки config/configurations/<slug>.json (Telegram), см. BOT_CONFIGURATION
  selectedBotConfigurationId String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]

  @@unique([channel, externalId])
}

model Conversation {
  id         String             @id @default(cuid())
  userId     String
  status     ConversationStatus @default(ACTIVE)
  stage      String             @default("contact")
  /// Имя активного скрипта (если в данный момент клиент в FSM). NULL когда диалог свободный.
  activeScript      String?
  /// Текущее состояние FSM: имя слота (`slot:service`) или служебное (`confirm`).
  activeScriptState String?
  /// Собранные значения слотов скрипта (key → value).
  activeScriptSlots Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model HandoffEvent {
  id             String   @id @default(cuid())
  conversationId String
  reason         String
  createdAt      DateTime @default(now())
}

model ProcessedInboundMessage {
  id                String   @id @default(cuid())
  channel           String
  externalMessageId String
  createdAt         DateTime @default(now())

  @@unique([channel, externalMessageId])
}

enum AdminRole {
  ADMIN
  MANAGER
}

/// Заготовка под multi-tenant: сейчас можно оставить пустым и не задавать tenantId у сущностей
model Tenant {
  id                String              @id @default(cuid())
  slug              String              @unique
  name              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  botConfigurations BotConfiguration[]
  promptProfiles    PromptProfile[]
}

/// Сборка бота (аналог config/configurations/<slug>.json), хранение в БД для админки
model BotConfiguration {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  slug      String   @unique
  name      String?
  data      Json
  version   Int      @default(1)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PromptProfile {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  slug      String   @unique
  data      Json
  version   Int      @default(1)
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             AdminRole @default(MANAGER)
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

/// Запись клиента (результат FSM-скрипта booking). Без FK на Conversation,
/// чтобы аудит-записи сохранялись даже после удаления диалога.
model Booking {
  id              String   @id @default(cuid())
  botId           String
  conversationId  String?
  service         String?
  date            String?
  time            String?
  name            String?
  phone           String?
  /// "confirmed" | "cancelled"
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())

  @@index([botId, createdAt])
  @@index([phone])
}

/// События для observability и биллинга: каждый ход = одна запись.
/// kind: 'snippet' (ответ без LLM), 'llm' (вызов модели), 'no_llm_fallback' (LLM выключен/упал), 'fsm' (FSM-шаг).
model BotUsage {
  id               String   @id @default(cuid())
  botId            String
  conversationId   String?
  kind             String
  snippetId        String?
  promptTokens     Int?
  completionTokens Int?
  model            String?
  createdAt        DateTime @default(now())

  @@index([botId, createdAt])
  @@index([createdAt])
  @@index([botId, kind, createdAt])
}
