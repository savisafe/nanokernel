# --- Published kernel hygiene: keep only the engine in the public repo ---
# Local business configurations & data (bot configs, prompt profiles, services,
# user/business data). They live on disk but must never be published.
/config/

# Internal docs & notes are private by default — only the public-facing set below
# is published (these contain no user/business data).
*.md
!/README.md
!/CONTRIBUTING.md
!/SECURITY.md
!/CODE_OF_CONDUCT.md
!/CHANGELOG.md
!/.github/**/*.md
